{
  "info": {
    "_postman_id": "ledger-backend-go-2026-v2",
    "name": "Ledger Backend Go",
    "description": "E-Wallet Hybrid System REST API collection.\n\nSetup:\n1. Ensure PostgreSQL is running (`docker compose up -d`) and `go run ./cmd/api` is active on port 8080.\n2. Run requests in order: Register budi, Register andi, Login budi, Login andi, dsb.\n3. JWT tokens are auto-saved to environment variables.\n\nDummy data: budi@mail.com / andi@mail.com (password: secret123)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register budi",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"budi\",\n  \"email\": \"budi@mail.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"]}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('budi_user_id', json.data.user_id);",
                  "  pm.environment.set('budi_wallet_id', json.data.wallet_id);",
                  "  console.log('Budi User ID:', json.data.user_id);",
                  "  console.log('Budi Wallet ID:', json.data.wallet_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Register andi",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"andi\",\n  \"email\": \"andi@mail.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/register", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "register"]}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('andi_user_id', json.data.user_id);",
                  "  pm.environment.set('andi_wallet_id', json.data.wallet_id);",
                  "  console.log('Andi User ID:', json.data.user_id);",
                  "  console.log('Andi Wallet ID:', json.data.wallet_id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login budi",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"budi@mail.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"]}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('budi_token', json.data.token);",
                  "  console.log('Budi token saved');",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login andi",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"andi@mail.com\",\n  \"password\": \"secret123\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/auth/login", "host": ["{{base_url}}"], "path": ["api", "v1", "auth", "login"]}
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.environment.set('andi_token', json.data.token);",
                  "  console.log('Andi token saved');",
                  "}"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "2. Wallet (Budi)",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{budi_token}}"}]
      },
      "item": [
        {
          "name": "Get Dashboard Summary",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/api/v1/wallet/dashboard", "host": ["{{base_url}}"], "path": ["api", "v1", "wallet", "dashboard"]}
          }
        },
        {
          "name": "TopUp 100000 (IDR)",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 100000,\n  \"notes\": \"top up awal budi\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/topup", "host": ["{{base_url}}"], "path": ["api", "v1", "topup"]}
          }
        },
        {
          "name": "Transfer 30000 to andi",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination_user_id\": \"{{andi_user_id}}\",\n  \"asset_symbol\": \"IDR\",\n  \"amount\": 30000,\n  \"notes\": \"bayar makan siang\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/transfer", "host": ["{{base_url}}"], "path": ["api", "v1", "transfer"]}
          }
        },
        {
          "name": "Get transaction history",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/api/v1/transactions?page=1&per_page=20", "host": ["{{base_url}}"], "path": ["api", "v1", "transactions"]}
          }
        }
      ]
    },
    {
      "name": "3. Wallet (Andi)",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{andi_token}}"}]
      },
      "item": [
        {
          "name": "Get Dashboard Summary (Andi)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/api/v1/wallet/dashboard", "host": ["{{base_url}}"], "path": ["api", "v1", "wallet", "dashboard"]}
          }
        },
        {
          "name": "Transfer 5000 to budi",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"destination_user_id\": \"{{budi_user_id}}\",\n  \"asset_symbol\": \"IDR\",\n  \"amount\": 5000,\n  \"notes\": \"kembalian\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/transfer", "host": ["{{base_url}}"], "path": ["api", "v1", "transfer"]}
          }
        }
      ]
    },
    {
      "name": "4. Exchange",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{budi_token}}"}]
      },
      "item": [
        {
          "name": "Get USDT_IDR Rate",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/exchange/rate?pair=USDT_IDR"
          }
        },
        {
          "name": "Swap 50000 IDR to USDT",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"from_asset\": \"IDR\",\n  \"to_asset\": \"USDT\",\n  \"amount\": 50000\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/exchange/swap", "host": ["{{base_url}}"], "path": ["api", "v1", "exchange", "swap"]}
          }
        }
      ]
    },
    {
      "name": "5. Crypto",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{budi_token}}"}]
      },
      "item": [
        {
          "name": "Get or Create Deposit Address (USDT)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/v1/crypto/address?network=polygon_amoy&asset_symbol=USDT"
          }
        },
        {
          "name": "Withdraw Crypto",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asset_symbol\": \"USDT\",\n  \"network\": \"polygon_amoy\",\n  \"to_address\": \"0x1234567890123456789012345678901234567890\",\n  \"amount\": 1.5,\n  \"notes\": \"withdrawal test\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/crypto/withdraw", "host": ["{{base_url}}"], "path": ["api", "v1", "crypto", "withdraw"]}
          }
        }
      ]
    },
    {
      "name": "6. Fiat Withdrawal",
      "auth": {
        "type": "bearer",
        "bearer": [{"key": "token", "value": "{{budi_token}}"}]
      },
      "item": [
        {
          "name": "Withdraw Fiat to Bank Account",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000,\n  \"bank_code\": \"bca\",\n  \"account_number\": \"1234567890\",\n  \"account_name\": \"Budi\",\n  \"notes\": \"withdraw test\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/fiat/withdraw", "host": ["{{base_url}}"], "path": ["api", "v1", "fiat", "withdraw"]}
          }
        }
      ]
    },
    {
      "name": "7. Webhooks",
      "item": [
        {
          "name": "Midtrans Payment Webhook",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"order_id\": \"TOPUP-IDR-12345\",\n  \"status_code\": \"200\",\n  \"gross_amount\": \"100000.00\",\n  \"signature_key\": \"dummy_signature\",\n  \"transaction_status\": \"settlement\"\n}"
            },
            "url": {"raw": "{{base_url}}/api/v1/webhooks/midtrans", "host": ["{{base_url}}"], "path": ["api", "v1", "webhooks", "midtrans"]}
          }
        },
        {
          "name": "Midtrans Iris Payout Webhook",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "[\n  {\n    \"payout_id\": 1234567,\n    \"reference_no\": \"{{budi_withdraw_tx_id}}\",\n    \"amount\": \"50000.00\",\n    \"status\": \"completed\"\n  }\n]"
            },
            "url": {"raw": "{{base_url}}/api/v1/webhooks/iris", "host": ["{{base_url}}"], "path": ["api", "v1", "webhooks", "iris"]}
          }
        }
      ]
    },
    {
      "name": "8. Health & Docs",
      "item": [
        {
          "name": "System Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"]}
          }
        },
        {
          "name": "Ping (Protected)",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{budi_token}}"}],
            "url": {"raw": "{{base_url}}/ping", "host": ["{{base_url}}"], "path": ["ping"]}
          }
        },
        {
          "name": "Swagger UI",
          "request": {
            "method": "GET",
            "header": [],
            "url": {"raw": "{{base_url}}/swagger/index.html", "host": ["{{base_url}}"], "path": ["swagger", "index.html"]}
          }
        }
      ]
    }
  ]
}
