DB_HOST=localhost
DB_PORT=1000
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ledger-db
DB_SSLMODE=disable
DB_LOG_LEVEL=warn

PORT=8080
JWT_EXPIRY_HOURS=24

# IMPORTANT: Replace this with a long random string in production.
# Generate one with: openssl rand -hex 32
JWT_SECRET=replace-me-with-a-long-random-secret

# === GOOGLE OAUTH2 ===
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-google-client-secret
GOOGLE_REDIRECT_URL=http://localhost:8080/api/v1/auth/google/callback

# === MIDTRANS SNAP ===
MIDTRANS_SERVER_KEY=SB-Mid-server-your-sandbox-server-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-sandbox-client-key
MIDTRANS_IS_PRODUCTION=false

# === MIDTRANS IRIS (DISBURSEMENT) ===
MIDTRANS_IRIS_API_KEY=IRIS-your-sandbox-iris-api-key
MIDTRANS_IRIS_BASE_URL=https://app.sandbox.midtrans.com/iris

# === ALCHEMY (BLOCKCHAIN RPC) ===
# Replace with your actual Alchemy API keys for Polygon Amoy
ALCHEMY_API_KEY=your-alchemy-api-key
ALCHEMY_NETWORK=polygon-amoy
ALCHEMY_HTTP_URL=https://polygon-amoy.g.alchemy.com/v2/your-api-key
ALCHEMY_WS_URL=wss://polygon-amoy.g.alchemy.com/v2/your-api-key

# === CRYPTO SMART CONTRACTS (TESTNET) ===
# Whitelisted contracts for USDT & USDC on Polygon Amoy
USDT_CONTRACT_ADDRESS=0x1fd3ba63f25418195d85265691136b80302b1f8c
USDC_CONTRACT_ADDRESS=0x9f5a77cc5cfdc60d70313f8c85fa7c14093f48a1

# === CRYPTO ENCRYPTION (AES-256-GCM) ===
# 32-byte key encoded in base64: "12345678901234567890123456789012"
CRYPTO_ENCRYPTION_KEY=MTIzNDU2Nzg5MDEyMzQ1Njc4OTAxMjM0NTY3ODkwMTI=

# === PRICE FEED ===
BINANCE_API_URL=https://api.binance.com/api/v3
USD_IDR_RATE=16200

# === SWAP platform fee ===
SWAP_FEE_PERCENTAGE=0.005
